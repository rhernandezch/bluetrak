# Bluetrak environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional unless noted.

# ── Database ────────────────────────────────────────────────────────────────
# When running via Docker Compose, use the path inside the container volume:
BLUETRAK_DB_PATH=/app/data/bluetrak.db
# When running locally without Docker, you can override this:
# BLUETRAK_DB_PATH=bluetrak.db

# ── Scheduler ───────────────────────────────────────────────────────────────
# BLUETRAK_FETCH_INTERVAL_MINUTES=15    # How often to fetch rates (minutes)

# ── Alert delivery ──────────────────────────────────────────────────────────
# At least one channel must be configured for alerts to be sent.

# Telegram (recommended)
#
# 1. Message @BotFather on Telegram, run /newbot, and copy the token it gives you.
# 2. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    The "chat":{"id": ...} value is your chat ID (negative for groups).
#
# BLUETRAK_TELEGRAM_BOT_TOKEN=          # e.g. 123456789:AAFxxxxxxx
# BLUETRAK_TELEGRAM_CHAT_ID=            # e.g. 123456789 (private) or -1001234567890 (group)

# Generic webhook (optional, can run alongside Telegram)
# BLUETRAK_WEBHOOK_URL=                 # POST endpoint; receives {"text": "..."}

# ── Alert thresholds ────────────────────────────────────────────────────────
# BLUETRAK_ALERT_PERCENTILE_THRESHOLD=90.0   # Fire when rate is in top N% of history
# BLUETRAK_ALERT_PERCENTILE_WINDOW_DAYS=7    # Lookback window for percentile (days)
# BLUETRAK_ALERT_TREND_WINDOW_DAYS=14        # Lookback window for trend fitting (days)
# BLUETRAK_ALERT_ARQ_REACTIVE_ENABLED=true   # Faster ARQ spike/drop alerts from raw samples
# BLUETRAK_ALERT_ARQ_REACTIVE_WINDOW_HOURS=6 # Raw ARQ lookback window
# BLUETRAK_ALERT_ARQ_REACTIVE_LOOKBACK=4     # Recent samples to compare (~1h at 15m fetches)
# BLUETRAK_ALERT_ARQ_REACTIVE_MIN_MOVE_ARS=3 # Minimum ARS move for ARQ fast alerts
# BLUETRAK_ALERT_ARQ_REACTIVE_MIN_MOVE_PCT=0.2 # Minimum percent move for ARQ fast alerts
# BLUETRAK_SELL_RATE_ALERT_ABOVE=0           # Legacy: simple rate threshold (0 = disabled)

# ── Per-source alert levels ────────────────────────────────────────────────
# Control which alerts you receive per source.
# Values: off, normal, high, every_change.
#   off          — no real-time alerts (data still collected and shown in summaries)
#   normal       — receive all ensemble sell-signal alerts (default)
#   high         — only receive HIGH urgency alerts (momentum fading near peak)
#   every_change — notify every time the sell rate changes (skips ensemble analysis)
#
# BLUETRAK_ALERT_LEVEL_ARQ=normal
# BLUETRAK_ALERT_LEVEL_WESTERN_UNION=normal
# BLUETRAK_ALERT_LEVEL_INFODOLAR_CCL=normal
