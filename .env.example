# Bluetrak environment configuration
# Copy this file to .env and fill in your values.
# All variables are optional unless noted.

# ── Database ────────────────────────────────────────────────────────────────
# BLUETRAK_DB_PATH=bluetrak.db          # Path to the SQLite database file

# ── Scheduler ───────────────────────────────────────────────────────────────
# BLUETRAK_FETCH_INTERVAL_MINUTES=15    # How often to fetch rates (minutes)

# ── Alert delivery ──────────────────────────────────────────────────────────
# At least one channel must be configured for alerts to be sent.

# Telegram (recommended)
#
# 1. Message @BotFather on Telegram, run /newbot, and copy the token it gives you.
# 2. Send a message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    The "chat":{"id": ...} value is your chat ID (negative for groups).
#
# BLUETRAK_TELEGRAM_BOT_TOKEN=          # e.g. 123456789:AAFxxxxxxx
# BLUETRAK_TELEGRAM_CHAT_ID=            # e.g. 123456789 (private) or -1001234567890 (group)

# Generic webhook (optional, can run alongside Telegram)
# BLUETRAK_WEBHOOK_URL=                 # POST endpoint; receives {"text": "..."}

# ── Alert thresholds ────────────────────────────────────────────────────────
# BLUETRAK_ALERT_PERCENTILE_THRESHOLD=90.0   # Fire when rate is in top N% of history
# BLUETRAK_ALERT_PERCENTILE_WINDOW_DAYS=7    # Lookback window for percentile (days)
# BLUETRAK_ALERT_TREND_WINDOW_DAYS=14        # Lookback window for trend fitting (days)
# BLUETRAK_SELL_RATE_ALERT_ABOVE=0           # Legacy: simple rate threshold (0 = disabled)
